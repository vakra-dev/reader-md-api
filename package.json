{
  "name": "@vakra-dev/reader-md-api",
  "version": "0.1.0",
  "description": "Free URL-to-markdown API. Prefix any URL to get clean markdown.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "scripts": {
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "test": "vitest run"
  },
  "dependencies": {
    "express": "^4.21.0",
    "express-rate-limit": "^7.5.0",
    "pino": "^9.0.0",
    "pino-http": "^10.0.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/node": "^20.10.6",
    "tsup": "^8.5.1",
    "tsx": "^4.19.0",
    "typescript": "^5.3.3",
    "vitest": "^4.1.0"
  },
  "engines": {
    "node": ">=18"
  }
}
